{
  "name": "zentcall-wa-bridge",
  "version": "1.0.0",
  "description": "WhatsApp Web bridge for ZentCall — monitors and forwards WA messages via @whiskeysockets/baileys",
  "main": "dist/index.js",
  "scripts": {
    "dev":   "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hapi/boom":              "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.9",
    "express":                 "^4.18.2",
    "qrcode":                  "^1.5.3",
    "pino":                    "^8.21.0"
  },
  "devDependencies": {
    "@types/express":  "^4.17.21",
    "@types/node":     "^20.11.0",
    "@types/qrcode":   "^1.5.5",
    "ts-node-dev":     "^2.0.0",
    "typescript":      "^5.3.3"
  }
}
