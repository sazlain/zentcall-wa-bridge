# URL interna de call-monitor (Docker: http://app:8080, local: http://localhost:8080)
BACKEND_URL=http://localhost:8080

# Token compartido entre el bridge y call-monitor para autenticar mensajes internos
BRIDGE_SECRET=change-me-in-production

# Puerto del servidor Express (no exponer al host — solo red Docker interna)
PORT=3002

# Directorio donde se persisten las sesiones de WhatsApp
SESSIONS_DIR=./sessions
